{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sentinel-MCP",
  "version": "0.3.0",
  "identifier": "dev.sentinel-mcp.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8766"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Sentinel-MCP",
        "width": 1180,
        "height": 780,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "url": "http://localhost:8766"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/sentinel-mcp-server"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Client-side AI agent tool-call security guard",
    "longDescription": "Sentinel-MCP intercepts every Model-Context-Protocol tool call between your AI agent and your local tools. Blocks prompt injection, path traversal, SSRF, shell injection, and redacts sensitive data leaving the machine."
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
